@page "/customers"
@rendermode InteractiveServer
@using BillingSystem.Services
@using BillingSystem.Models
@inject DataService DS

<PageTitle>Customers - Billing System</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">👥 Customers</h2>
    <a href="/customers/add" class="btn btn-primary">+ Add Customer</a>
</div>

<!-- Search -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <input class="form-control" placeholder="🔍 Search by name, phone, email..." @bind="searchText" @bind:event="oninput" />
    </div>
</div>

@if (customers == null)
{
    <p>Loading...</p>
}
else if (!filteredCustomers.Any())
{
    <div class="text-center py-5 text-muted">
        <div class="fs-1">👥</div>
        <p>No customers found. <a href="/customers/add">Add your first customer</a></p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>GST No.</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (c, i) in filteredCustomers.Select((c, i) => (c, i + 1)))
                        {
                            <tr>
                                <td>@i</td>
                                <td><strong>@c.Name</strong><br /><small class="text-muted">@c.Address</small></td>
                                <td>@c.Phone</td>
                                <td>@c.Email</td>
                                <td>@c.GSTNumber</td>
                                <td>
                                    <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">
                                        @(c.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <a href="/customers/edit/@c.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(c)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="text-muted small mt-2">Showing @filteredCustomers.Count of @customers.Count customers</div>
}

<!-- Delete Confirm Modal -->
@if (deleteTarget != null)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete <strong>@deleteTarget.Name</strong>?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => deleteTarget = null">Cancel</button>
                    <button class="btn btn-danger" @onclick="DoDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Customer>? customers;
    private string searchText = "";
    private Customer? deleteTarget;

    private List<Customer> filteredCustomers => customers?
        .Where(c => string.IsNullOrEmpty(searchText) ||
                    c.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Phone.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        .OrderBy(c => c.Name).ToList() ?? new();

    protected override void OnInitialized()
    {
        customers = DS.GetCustomers();
    }

    private void ConfirmDelete(Customer c) => deleteTarget = c;

    private void DoDelete()
    {
        if (deleteTarget != null)
        {
            DS.DeleteCustomer(deleteTarget.Id);
            customers = DS.GetCustomers();
            deleteTarget = null;
        }
    }
}
